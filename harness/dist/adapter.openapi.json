  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/commands/cleaning-robot": {
      "post": {
        "description": "@brief 清洁机器人命令(ack 受理语义)",
        "operationId": "commands_cleaning_robot",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CleaningRobotCommandRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CleaningRobotCommandResult"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Commands Cleaning Robot"
      }
    },
    "/api/v1/commands/flycart": {
