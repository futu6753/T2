# =============================================================================
# 港电统一平台 环境变量占位模板(仓库只允许本模板,真实值见密钥保管处,H00 G7)
# 部署要求:.env 文件权限 600、离线备份、禁截图外传(H04 §九)
# =============================================================================

# ---- 运行模式(默认 0=生产,不配置即安全;H05 §1) ----
DEMO_MODE=0
# DEMO_ALLOW_EXPOSED=1        # 仅隔离测试网:放行 DEMO 绑定非回环地址

# ---- 密码套件(默认 intl;切 gm 须显式设置并走迁移脚本,H04 §8.2) ----
CRYPTO_SUITE=intl

# ---- 主密钥(scripts/gen_master_key.py 生成;更换必须走 rotate_master_key 迁移) ----
MASTER_KEY_HEX=CHANGE_ME
MASTER_KEY_ID=mk1

# ---- 数据库(生产 PostgreSQL / 开发单机 SQLite,H12 §一) ----
GD_DB_URL=sqlite:///data/platform.db
# GD_DB_URL=postgresql://user:CHANGE_ME@db-host:5432/gangdian

# ---- Redis(生产必配;不可用时 fail-closed,H12 §五) ----
REDIS_URL=redis://CHANGE_ME:6379/0

# ---- RP 侧 SSO 接入(缺任一必填项则 SSO 不启用,H08 §3) ----
SSO_ISSUER=CHANGE_ME
SSO_CLIENT_ID=CHANGE_ME
SSO_CLIENT_SECRET=CHANGE_ME
SSO_REDIRECT=CHANGE_ME
