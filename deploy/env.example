# 港电统一平台环境变量模板(复制为 .env 并 chmod 600;值禁入版本库,H00 G7)
# 单机六系统部署配套;deploy/bootstrap.sh 会自动生成 PG_PASSWORD/主密钥/
# 六 RP 的 SSO 密钥并回填,通常无需手工填写。手工部署时按注释逐项填。

# ---- 数据层 ----
PG_PASSWORD=请生成强口令
# DATABASE_URL/REDIS_URL 在 compose 内由服务名解析,单机默认无需改:
DATABASE_URL=postgresql://gd:${PG_PASSWORD}@postgres/gangdian
REDIS_URL=redis://redis:6379/0

# ---- 主密钥(scripts/gen_master_key.py 生成;更换必须走 rotate_master_key)----
MASTER_KEY_HEX=
MASTER_KEY_ID=mk1
# 轮换迁移期临时启用(完成后移除):
# OLD_MASTER_KEY_HEX=
# OLD_MASTER_KEY_ID=mk0

# ---- 密码套件(统一预置 intl;切 gm 须全实例一致并读 runbook_suite_migration.md)----
CRYPTO_SUITE=intl
# 双写窗口(仅套件迁移期开启,值为副套件名):
# CRYPTO_DUAL_WRITE=gm

# ---- SSO(六域名;单机自签默认 *.gangdian.internal,可整体改域名)----
SSO_ISSUER=https://sso.gangdian.internal
# 四 RP 的 client_secret:由 scripts/register_sso_clients.py 生成后回填
CV_SSO_SECRET=
NVR_SSO_SECRET=
F3D_SSO_SECRET=
QUIZ_SSO_SECRET=
# 回调地址(默认按上面域名;改域名时同步改这四项与 register 脚本 --base-domain)
CV_REDIRECT=https://cv.gangdian.internal/sso/callback
NVR_REDIRECT=https://nvr.gangdian.internal/sso/callback
F3D_REDIRECT=https://f3d.gangdian.internal/sso/callback
QUIZ_REDIRECT=https://quiz.gangdian.internal/sso/callback

# ---- factory3d 应急脚本令牌(可空;配置 SSO 后人机界面不用它)----
F3D_ADMIN_TOKEN=

# ---- 模式(生产禁 DEMO_MODE)----
# DEMO_MODE=
