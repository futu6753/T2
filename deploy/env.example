# 港电统一平台环境变量模板(复制为 .env 并 chmod 600;值禁入版本库,H00 G7)
# ---- 数据层 ----
PG_PASSWORD=请生成强口令
DATABASE_URL=postgresql://gd:${PG_PASSWORD}@postgres/gangdian
REDIS_URL=redis://redis:6379/0
# ---- 主密钥(scripts/gen_master_key.py 生成;更换必须走 rotate_master_key)----
MASTER_KEY_HEX=
MASTER_KEY_ID=mk1
# 轮换迁移期临时启用(完成后移除):
# OLD_MASTER_KEY_HEX=
# OLD_MASTER_KEY_ID=mk0
# ---- 密码套件(统一预置 intl;切 gm 须全实例一致并先阅读 docs/runbook_suite_migration.md)----
CRYPTO_SUITE=intl
# 双写窗口(仅套件迁移期开启,值为副套件名):
# CRYPTO_DUAL_WRITE=gm
# ---- SSO 客户端密钥(IdP 管理台登记后填入)----
CV_SSO_SECRET=
# ---- 模式(生产禁 DEMO_MODE)----
# DEMO_MODE=
